# Miru Tracer Environment Configuration
# Copy this file to .env and adjust values as needed

# Enable debug mode (1 or true = enabled, 0 or false = disabled)
# When enabled, Interactive Mode will log detailed information including:
# - Session creation/deletion
# - State information before/after operations
# - Token selection details
# - Probability distributions
# - State validation results
# This is useful for troubleshooting but produces verbose output
MIRU_DEBUG=0

# Server configuration
# Server name/host to bind to (use 0.0.0.0 to expose to network)
MIRU_SERVER_NAME=127.0.0.1

# Server port to listen on
MIRU_SERVER_PORT=7860
