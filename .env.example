# Miru Tracer Environment Configuration
# Copy this file to .env and adjust values as needed

# Enable debug mode (1/true/yes/on = enabled, anything else = disabled)
# Enables debug-level logging and Gradio's debug mode.
MIRU_DEBUG=0

# Server configuration
# Bind address (use 0.0.0.0 to expose to the network)
MIRU_SERVER_NAME=127.0.0.1
# Bind port
MIRU_SERVER_PORT=7860

# Optional basic authentication. Set both or neither.
# Strongly recommended whenever MIRU_SERVER_NAME is not loopback.
#MIRU_AUTH_USERNAME=
#MIRU_AUTH_PASSWORD=

# Remote Hugging Face repository code is disabled by default because loading
# it executes third-party Python in the app process.
#MIRU_ALLOW_REMOTE_CODE=0

# Server-side resource ceilings (UI controls cannot bypass these values)
#MIRU_MAX_NEW_TOKENS=1000
#MIRU_MAX_LOG_TOP_K=256
#MIRU_MAX_FULL_PROB_STEPS=128
#MIRU_MAX_LENS_CELLS=8192

# Directory for fitted Jacobian-lens artifacts
# (default: ~/.cache/miru-tracer/lenses)
#MIRU_LENS_DIR=

# HuggingFace token — only needed for gated models
#HF_TOKEN=

# Docker-only: optional SSH server inside the container
#MIRU_SSH_ENABLE=0
#MIRU_SSH_PORT=22
#MIRU_SSH_AUTHORIZED_KEYS=
