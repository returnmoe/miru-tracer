# Miru Tracer Environment Configuration
# Copy this file to .env and adjust values as needed

# Enable debug mode (1/true/yes/on = enabled, anything else = disabled)
# Enables debug-level logging and Gradio's debug mode.
MIRU_DEBUG=0

# Server configuration
# Bind address (use 0.0.0.0 to expose to the network)
MIRU_SERVER_NAME=127.0.0.1
# Bind port
MIRU_SERVER_PORT=7860

# Directory for fitted Jacobian-lens artifacts
# (default: ~/.cache/miru-tracer/lenses)
#MIRU_LENS_DIR=

# HuggingFace token — only needed for gated models
#HF_TOKEN=

# Docker-only: optional SSH server inside the container
#MIRU_SSH_ENABLE=0
#MIRU_SSH_PORT=22
#MIRU_SSH_AUTHORIZED_KEYS=
